# Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_CLAVE_PUBLICA_ANON

# SERVER-ONLY. Nunca uses NEXT_PUBLIC_ ni la importes en componentes cliente.
# Actualmente es opcional/reservada para mantenimiento administrativo.
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Solo desarrollo local. El código ignora este valor cuando NODE_ENV=production.
# En Vercel Production déjala ausente o en false.
NEXT_PUBLIC_DEMO_MODE=false

# Configuración visible del portafolio
NEXT_PUBLIC_DOCENTE_NOMBRE=Nombre del docente
NEXT_PUBLIC_DOCENTE_AREA=Informática
NEXT_PUBLIC_DOCENTE_JORNADA=Matutina

# Las cargas de PDF, HTML e imágenes tienen un límite fijo de 4 MB para
# mantenerse dentro del límite de la petición multipart en Vercel.

# Solo pruebas locales automatizadas; no las cargues en Vercel.
E2E_APP_URL=http://localhost:3000
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
