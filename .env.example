# Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_CLAVE_PUBLICA_ANON

# SERVER-ONLY. Nunca uses NEXT_PUBLIC_ ni la importes en componentes cliente.
# Requerida en Vercel para la purga automática de la papelera.
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# SERVER-ONLY. Se recomienda una cadena aleatoria de 32 caracteres o más.
# Vercel la envía como Authorization: Bearer al cron diario.
CRON_SECRET=GENERA_UN_SECRETO_ALEATORIO

# Solo desarrollo local. El código ignora este valor cuando NODE_ENV=production.
# En Vercel Production déjala ausente o en false.
NEXT_PUBLIC_DEMO_MODE=false

# Valores públicos de respaldo. El nombre real sale de perfiles y el área/jornada
# del portafolio activo; estas variables son opcionales.
NEXT_PUBLIC_DOCENTE_NOMBRE=Nombre del docente
NEXT_PUBLIC_DOCENTE_AREA=Informática
NEXT_PUBLIC_DOCENTE_JORNADA=Matutina

# La carga normal usa una URL firmada directa a Storage: 20 MB para documentos
# e imágenes y 50 MB para MP4/WebM. Estos límites también se aplican en Storage.

# Solo pruebas locales automatizadas; no las cargues en Vercel.
E2E_APP_URL=http://localhost:3000
# CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Las pruebas E2E y visuales crean y eliminan usuarios/documentos temporales.
# Usa preferiblemente un proyecto Supabase separado de staging.
ALLOW_REMOTE_TESTS=false
REMOTE_TEST_TARGET=staging
REMOTE_TEST_PROJECT_REFS=REF_EXACTA_DEL_PROYECTO_STAGING
# Solo para una ejecucion excepcional y deliberada contra produccion:
ALLOW_PRODUCTION_REMOTE_TESTS=false
